<!DOCTYPE html>
<html lang="es">
<head>
  <script type="module" src="/@vite/client"></script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Carlos Ercoli - Plomero y Gasista Matriculado. Más de 30 años de experiencia en instalaciones de agua y gas, reparaciones, reformas y colocación de artefactos en Berazategui, Ranelagh, Ezpeleta y Quilmes.">
  <title>Carlos Ercoli | Plomero y Gasista Matriculado</title>
  
  <!-- Google Fonts: Inter para texto de lectura, Outfit para títulos elegantes -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- CSS Personalizado -->
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <!-- Barra de Navegación -->
  <header class="main-header" id="header">
    <div class="header-container">
      <a href="#inicio" class="logo" id="logo-link">
        <span class="logo-name">Carlos Ercoli</span>
        <span class="logo-badge">Gasista y Plomero Matriculado</span>
      </a>
      
      <!-- Botón Hamburguesa para móviles -->
      <button class="mobile-menu-toggle" id="menu-toggle" aria-label="Abrir menú">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="nav-menu" id="nav-menu">
        <ul>
          <li><a href="#inicio" class="nav-link active">Inicio</a></li>
          <li><a href="#servicios" class="nav-link">Servicios</a></li>
          <li><a href="#elegirme" class="nav-link">¿Por qué elegirme?</a></li>
          <li><a href="#galeria" class="nav-link">Trabajos</a></li>
          <li><a href="#zona" class="nav-link">Zona de Trabajo</a></li>
          <li><a href="#contacto" class="nav-link btn-header-cta">Pedir Presupuesto</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Sección Hero -->
  <section id="inicio" class="hero-section">
    <div class="hero-bg-accent"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <div class="badge-matriculado pulse-element">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="icon-spark"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Gasista Matriculado & Plomero Profesional
        </div>
        
        <h1 class="hero-title">Plomero y Gasista Matriculado</h1>
        
        <p class="hero-subtitle">
          Más de <strong>30 años de experiencia</strong> brindando soluciones de agua y gas en zona sur. Trabajos con eficacia, responsabilidad, prolijidad y atención 100% personalizada.
        </p>
        
        <div class="hero-actions">
          <a href="#contacto" class="btn btn-primary" id="hero-btn-presupuesto">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            Solicitar Presupuesto
          </a>
          <a href="https://wa.me/5491161753059?text=Hola%20Carlos,%20vi%20tu%20p%C3%A1gina%20web%20y%20quer%C3%ADa%20hacerte%20una%20consulta." target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp" id="hero-btn-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            Consultar por WhatsApp
          </a>
        </div>
        
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-num">30+</span>
            <span class="stat-text">Años de Trayectoria</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">Atención</span>
            <span class="stat-text">Personalizada</span>
          </div>
        </div>
      </div>
      
      <div class="hero-visual">
        <div class="hero-card-wrapper">
          <img src="/images/input_file_2.png" alt="Instalación de tanque de agua y colector" class="hero-img">
          <div class="hero-img-overlay"></div>
          
          <!-- Badges flotantes en la imagen -->
          <div class="floating-badge badge-top">
            <span class="badge-dot"></span>
            Trabajo 100% Real
          </div>
          <div class="floating-badge badge-bottom">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0e7490" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Instalaciones Seguras
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección Servicios -->
  <section id="servicios" class="section-padding servicios-section">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Lo que hago</span>
        <h2 class="section-title">Servicios Profesionales de Agua y Gas</h2>
        <p class="section-description">
          Soluciones integrales con materiales de primera calidad y bajo las estrictas normativas de seguridad vigentes.
        </p>
      </div>

      <div class="services-grid">
        <!-- Servicio 1 -->
        <div class="service-card reveal-on-scroll" id="service-1">
          <div class="service-icon-wrapper water-accent">
            <!-- Icono Termofusión / Agua -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3 class="service-card-title">Instalaciones de agua</h3>
          <p class="service-card-text">
            Tendido de cañerías en termofusión (Acqua System, IPS), colocación de tanques de agua, bombas presurizadoras y colectores a medida para óptima presión.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>

        <!-- Servicio 2 -->
        <div class="service-card reveal-on-scroll" id="service-2">
          <div class="service-icon-wrapper gas-accent">
            <!-- Icono Gas -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><path d="M12 2c5.523 0 10 4.477 10 10S17.523 22 12 22 2 17.523 2 12 6.477 2 12 2z"></path><path d="M12 6v12M8 10h8M8 14h8"></path></svg>
          </div>
          <h3 class="service-card-title">Instalaciones de gas</h3>
          <p class="service-card-text">
            Instalaciones de cañerías epoxi o Sigas por termofusión. Presentación de planos ante Metrogas, trámites de habilitación y pruebas de hermeticidad certificadas.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>

        <!-- Servicio 3 -->
        <div class="service-card reveal-on-scroll" id="service-3">
          <div class="service-icon-wrapper repair-accent">
            <!-- Icono Reparaciones -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3 class="service-card-title">Reparaciones</h3>
          <p class="service-card-text">
            Detección y reparación de filtraciones, fugas de gas con manómetro, destapaciones de cañerías de agua fría y caliente, cambio de llaves de paso oxidadas.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>

        <!-- Servicio 4 -->
        <div class="service-card reveal-on-scroll" id="service-4">
          <div class="service-icon-wrapper reform-accent">
            <!-- Icono Reformas -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line></svg>
          </div>
          <h3 class="service-card-title">Reformas</h3>
          <p class="service-card-text">
            Modernización integral de cocinas, baños y lavaderos. Reemplazo de cañerías antiguas de plomo o hierro por materiales modernos de alta durabilidad.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>

        <!-- Servicio 5 -->
        <div class="service-card reveal-on-scroll" id="service-5">
          <div class="service-icon-wrapper expansion-accent">
            <!-- Icono Ampliaciones -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
          </div>
          <h3 class="service-card-title">Ampliaciones</h3>
          <p class="service-card-text">
            Creación de nuevas bocas de gas para calefactores, extensión de líneas de agua para lavarropas, piletas de patio, quinchos o nuevas plantas residenciales.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>

        <!-- Servicio 6 -->
        <div class="service-card reveal-on-scroll" id="service-6">
          <div class="service-icon-wrapper appliance-accent">
            <!-- Icono Artefactos -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="service-icon"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
          </div>
          <h3 class="service-card-title">Colocación de artefactos</h3>
          <p class="service-card-text">
            Instalación profesional de cocinas, termotanques, calefones, calderas, calefactores tiro balanceado, cocinas comerciales, sanitarios, vanitorys y grifería de alta gama.
          </p>
          <span class="service-link">Consultar servicio &rarr;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección ¿Por qué elegirme? -->
  <section id="elegirme" class="section-padding elegirme-section">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Compromiso y Confianza</span>
        <h2 class="section-title">¿Por qué elegir mi servicio?</h2>
        <p class="section-description">
          Trabajo de manera independiente desde hace más de tres décadas, ofreciendo la seriedad y seguridad que tu hogar e inversión merecen.
        </p>
      </div>

      <div class="elegirme-grid">
        <!-- Beneficio 1 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <div class="elegirme-content">
            <h3>Más de 30 años de experiencia</h3>
            <p>Toda una vida dedicada al rubro. He solucionado problemas complejos en todo tipo de viviendas y consorcios, garantizando soluciones de fondo.</p>
          </div>
        </div>

        <!-- Beneficio 2 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <div class="elegirme-content">
            <h3>Atención personalizada</h3>
            <p>Trato directo con el cliente de principio a fin. Sin intermediarios ni empresas tercerizadas. Te asesoro personalmente sobre la mejor alternativa.</p>
          </div>
        </div>

        <!-- Beneficio 3 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div class="elegirme-content">
            <h3>Trabajo prolijo e impecable</h3>
            <p>La prolijidad es mi sello distintivo. Planifico las canaletas y roturas al mínimo indispensable y realizo una limpieza profunda al terminar el trabajo.</p>
          </div>
        </div>

        <!-- Beneficio 4 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <div class="elegirme-content">
            <h3>Presupuesto sin compromiso</h3>
            <p>Evaluación detallada, honesta y transparente sobre lo que realmente necesitás hacer, explicándote el paso a paso y los costos de los materiales.</p>
          </div>
        </div>

        <!-- Beneficio 5 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 14 14"></polyline></svg>
          </div>
          <div class="elegirme-content">
            <h3>Responsabilidad y Matrícula</h3>
            <p>Normas de seguridad rígidas en gas. Trabajos garantizados que pasan exitosamente las inspecciones oficiales de las prestatarias de servicio.</p>
          </div>
        </div>

        <!-- Beneficio 6 -->
        <div class="elegirme-card reveal-on-scroll">
          <div class="elegirme-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="elegirme-icon"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <div class="elegirme-content">
            <h3>Respuesta rápida por WhatsApp</h3>
            <p>Canal directo abierto las 24 horas para urgencias, consultas rápidas y coordinación inmediata de visitas para diagnóstico técnico en la zona.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección Galería de Trabajos -->
  <section id="galeria" class="section-padding galeria-section">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Portfolio de obras</span>
        <h2 class="section-title">Galería de Trabajos Reales realizados</h2>
        <p class="section-description">
          Registros fotográficos reales en obras y domicilios de clientes de la zona. Trabajo garantizado y de excelencia.
        </p>
      </div>

      <!-- Filtro de Galería -->
      <div class="gallery-filter-container">
        <button class="filter-btn active" data-filter="all">Todos los trabajos</button>
        <button class="filter-btn" data-filter="agua">Instalaciones de Agua</button>
        <button class="filter-btn" data-filter="gas">Instalaciones de Gas</button>
      </div>

      <!-- Grid de Galería -->
      <div class="gallery-grid" id="gallery-grid">
        <!-- Trabajo 1 (Agua / Biodigestor) -->
        <div class="gallery-item reveal-on-scroll" data-category="agua" id="gallery-item-1">
          <div class="gallery-image-wrapper">
            <img src="/images/input_file_0.png" alt="Instalación de Biodigestor subterráneo y tuberías de termofusión verdes" class="gallery-thumbnail">
            <div class="gallery-item-hover">
              <div class="gallery-item-info">
                <button class="btn-expand-img" aria-label="Ampliar imagen">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Trabajo 2 (Gas / Gabinete) -->
        <div class="gallery-item reveal-on-scroll" data-category="gas" id="gallery-item-2">
          <div class="gallery-image-wrapper">
            <img src="/images/input_file_1.png" alt="Gabinete de gas con cañerías epoxi pintadas de amarillo y medidor regulador" class="gallery-thumbnail">
            <div class="gallery-item-hover">
              <div class="gallery-item-info">
                <button class="btn-expand-img" aria-label="Ampliar imagen">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Trabajo 3 (Agua / Tanque) -->
        <div class="gallery-item reveal-on-scroll" data-category="agua" id="gallery-item-3">
          <div class="gallery-image-wrapper">
            <img src="/images/input_file_2.png" alt="Tanque de agua Rotoplas de gran capacidad en azotea con cañerías marrones termofusión" class="gallery-thumbnail">
            <div class="gallery-item-hover">
              <div class="gallery-item-info">
                <button class="btn-expand-img" aria-label="Ampliar imagen">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox Modal para ampliar imágenes -->
  <div class="lightbox-modal" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar ventana">&times;</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Imagen anterior">&#10094;</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="Siguiente imagen">&#10095;</button>
    <div class="lightbox-content">
      <img src="" alt="" id="lightbox-img">
      <div class="lightbox-caption">
        <span id="lightbox-category">Categoría</span>
        <h4 id="lightbox-title">Título de la imagen</h4>
        <p id="lightbox-desc">Descripción detallada</p>
      </div>
    </div>
  </div>

  <!-- Sección Interactiva: Cotizador Rápido de Presupuestos -->
  <section id="contacto" class="section-padding cotizador-section">
    <div class="container">
      <div class="cotizador-card">
        <div class="cotizador-header">
          <span class="badge-matriculado">Cotizá en 1 Minuto</span>
          <h2>Solicitar Presupuesto por WhatsApp</h2>
          <p>Completá estos datos sencillos y el sistema armará un mensaje estructurado y prolijo para enviármelo directamente a mi WhatsApp. ¡Te responderé al instante!</p>
        </div>
        
        <form id="quote-form" class="quote-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="client-name">Tu Nombre y Apellido *</label>
              <input type="text" id="client-name" name="name" placeholder="Ej: Juan Pérez" required>
            </div>
            
            <div class="form-group">
              <label for="client-location">Tu Barrio / Localidad *</label>
              <select id="client-location" name="location" required>
                <option value="" disabled selected>Seleccioná tu localidad</option>
                <option value="Berazategui">Berazategui</option>
                <option value="Ranelagh">Ranelagh</option>
                <option value="Ezpeleta">Ezpeleta</option>
                <option value="Quilmes">Quilmes</option>
                <option value="Otra">Otra zona de cobertura cercana</option>
              </select>
            </div>

            <div class="form-group">
              <label for="service-type">Tipo de Servicio Requerido *</label>
              <select id="service-type" name="service" required>
                <option value="" disabled selected>Seleccioná el rubro</option>
                <option value="Instalaciones de agua">Instalaciones de Agua</option>
                <option value="Instalaciones de gas">Instalaciones de Gas / Planos</option>
                <option value="Reparaciones generales">Reparaciones de Pérdidas / Fugas</option>
                <option value="Reformas integrales">Reforma de Baño / Cocina</option>
                <option value="Ampliaciones">Ampliación de bocas / Cañería</option>
                <option value="Colocación de artefactos">Colocación de Calefactor, Cocina o Termotanque</option>
